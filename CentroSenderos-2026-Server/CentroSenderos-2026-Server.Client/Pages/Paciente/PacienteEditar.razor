@page "/pacientes/editar/{id:int}"
@using CentroSenderos_2026_Shared.DTO
@using CentroSenderos_2026_Shared.Enum
@inject IHttpServicio Http
@inject NavigationManager Nav
@rendermode InteractiveAuto

<h3>Editar Paciente</h3>

@if (cargando)
{
    <p>Cargando datos del paciente...</p>
}
else if (modelo == null)
{
    <p>No se encontró el paciente.</p>
}
else
{
    <EditForm Model="@modelo" OnValidSubmit="Grabar" FormName="EditarPacienteForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <h5>Datos Personales</h5>
        <div class="form-group">
            <label>ID</label>
            <InputNumber class="form-control" @bind-Value="modelo.Id" disabled />
        </div>

        <div class="form-group">
            <label>Nombre Completo</label>
            <InputText class="form-control" @bind-Value="modelo.Nombre" placeholder = "Ej: Juan Pérez" />
            <ValidationMessage For="@(() => modelo.Nombre)" />
        </div>

        <div class="form-group">
            <label>DNI</label>
            <InputText class="form-control" @bind-Value="modelo.DNI" placeholder="Ej: 12345678" />
            <ValidationMessage For="@(() => modelo.DNI)" />
        </div>

        <div class="form-group">
            <label>Número de Afiliado</label>
            <InputNumber class="form-control" @bind-Value="modelo.NumeroAfiliado" />
            <ValidationMessage For="@(() => modelo.NumeroAfiliado)" />
        </div>

        <div class="form-group">
            <label>Teléfono</label>
            <InputText class="form-control" @bind-Value="modelo.Telefono" placeholder="Ej: +54 351 555-1234" />
            <ValidationMessage For="@(() => modelo.Telefono)" />
        </div>

        <div class="form-group">
            <label>Domicilio</label>
            <InputText class="form-control" @bind-Value="modelo.Domicilio" placeholder="Ej: Av. Siempre Viva 742" />
            <ValidationMessage For="@(() => modelo.Domicilio)" />
        </div>

        <h5>Datos Médicos</h5>
        <div class="form-group">
            <label>Obra Social</label>
            <InputSelect class="form-control" @bind-Value="modelo.TipoObraSocialId">
                <option value="1">OSDE</option>
                <option value="2">IOMA</option>
                <option value="3">SURA</option>
                <option value="4">Swiss Medical</option>
                <option value="5">Medifé</option>
                <option value="6">Galeno</option>
                <option value="7">BMI</option>
                <option value="8">Accord Salud</option>
                <option value="9">Particular</option>
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Diagnóstico</label>
            <InputSelect class="form-control" @bind-Value="modelo.TipoDiagnosticoId">
                <option value="1">Trastorno del Espectro Autista (TEA)</option>
                <option value="2">Parálisis Cerebral</option>
                <option value="3">Síndrome de Down</option>
                <option value="4">Discapacidad Intelectual</option>
                <option value="5">Dislexia</option>
                <option value="6">Dispraxia</option>
                <option value="7">Trastorno del Lenguaje</option>
                <option value="8">TDAH</option>
                <option value="9">TGD</option>
                <option value="10">Hipoacusia</option>
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Estado Registro</label>
            <InputSelect class="form-control" @bind-Value="modelo.EstadoRegistro">
                <option value="0">EnGrabacion</option>
                <option value="1">Activo</option>
                <option value="2">Inactivo</option>
            </InputSelect>
        </div>

        <br />
        <button class="btn btn-primary" type="submit">Guardar Cambios</button>
        <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
    </EditForm>
}

<p>@Mensaje</p>

@code {
    [Parameter]
    public int Id { get; set; }

    private PacienteDTO modelo = new PacienteDTO
    {
        Nombre = string.Empty,
        DNI = string.Empty,
        Telefono = string.Empty,
        Domicilio = string.Empty,
        NumeroAfiliado = 0,
        TipoObraSocialId = 1,
        TipoDiagnosticoId = 1,
        EstadoRegistro = EnumEstadoRegistro.EnGrabacion
    };
    private bool cargando = true;
    private string Mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarPaciente();
    }

    private async Task CargarPaciente()
    {
        cargando = true;
        var resp = await Http.Get<PacienteDTO>($"api/paciente/{Id}");
        if (!resp.Error)
        {
            modelo = resp.Respuesta;
        }
        else
        {
            Mensaje = resp.ObtenerError();
        }
        cargando = false;
    }


    private async Task Grabar()
    {
        if (modelo == null) return;

        var resp = await Http.Put<PacienteDTO, RespuestaDTO>($"api/paciente/{Id}", modelo);
        Mensaje = resp.Error ? resp.ObtenerError() : resp.Respuesta?.mensaje!;

        if (!resp.Error)
        {
            await Task.Delay(500);
            Nav.NavigateTo("/pacientes", true);
        }
    }



    private void Cancelar()
    {
        Nav.NavigateTo("/pacientes");
    }
}
