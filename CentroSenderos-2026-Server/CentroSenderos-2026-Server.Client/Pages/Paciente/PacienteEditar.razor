@page "/pacientes/editar/{id:int}"
@using CentroSenderos_2026_Shared.DTO
@using CentroSenderos_2026_Shared.Enum
@inject IHttpServicio Http
@inject NavigationManager Nav
@rendermode InteractiveAuto

<h3>Editar Paciente</h3>

@if (cargando)
{
    <p>Cargando datos del paciente...</p>
}
else if (modelo == null)
{
    <p>No se encontró el paciente.</p>
}
else
{
    <EditForm Model="@modelo" OnValidSubmit="Grabar" FormName="EditarPacienteForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <h5>Datos Personales</h5>
        <div class="form-group">
            <label>ID</label>
            <InputNumber class="form-control" @bind-Value="modelo.Id" disabled />
        </div>

        <div class="form-group">
            <label>Nombre Completo</label>
            <InputText class="form-control" @bind-Value="modelo.Nombre" />
            <ValidationMessage For="@(() => modelo.Nombre)" />
        </div>

        <div class="form-group">
            <label>DNI</label>
            <InputText class="form-control" @bind-Value="modelo.DNI" />
            <ValidationMessage For="@(() => modelo.DNI)" />
        </div>

        <div class="form-group">
            <label>Número de Afiliado</label>
            <InputNumber class="form-control" @bind-Value="modelo.NumeroAfiliado" />
            <ValidationMessage For="@(() => modelo.NumeroAfiliado)" />
        </div>

        <div class="form-group">
            <label>Teléfono</label>
            <InputText class="form-control" @bind-Value="modelo.Telefono" />
        </div>

        <div class="form-group">
            <label>Domicilio</label>
            <InputText class="form-control" @bind-Value="modelo.Domicilio" />
        </div>

        <h5>Datos Médicos</h5>
        <div class="form-group">
            <label>Obra Social</label>
            <InputSelect class="form-control" @bind-Value="modelo.TipoObraSocialId">
                @foreach (var obra in tiposObraSocial)
                {
                    <option value="@obra.Id">@obra.Tipo</option>
                }
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Diagnóstico</label>
            <InputSelect class="form-control" @bind-Value="modelo.TipoDiagnosticoId">
                @foreach (var diag in tiposDiagnostico)
                {
                    <option value="@diag.Id">@diag.Tipo</option>
                }
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Estado Registro</label>
            <InputSelect class="form-control" @bind-Value="modelo.EstadoRegistro">
                @foreach (EnumEstadoRegistro estado in Enum.GetValues(typeof(EnumEstadoRegistro)))
                {
                    <option value="@estado">@estado</option>
                }
            </InputSelect>
        </div>

        <br />
        <button class="btn btn-primary" type="submit">Guardar Cambios</button>
        <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
    </EditForm>
}

<p>@Mensaje</p>

@code {
    [Parameter]
    public int Id { get; set; }

    private PacienteDTO? modelo;
    private bool cargando = true;
    private string Mensaje = "";

    private List<TipoDTO> tiposObraSocial = new();
    private List<TipoDTO> tiposDiagnostico = new();

    protected override async Task OnInitializedAsync()
    {
        cargando = true;

        // cargar listas
        var respObra = await Http.Get<List<TipoDTO>>("api/tipoobrasocial/ListaTipoObraSocial");
        if (!respObra.Error && respObra.Respuesta != null)
            tiposObraSocial = respObra.Respuesta;

        var respDiag = await Http.Get<List<TipoDTO>>("api/tipodiagnostico/ListaTipoDiagnostico");
        if (!respDiag.Error && respDiag.Respuesta != null)
            tiposDiagnostico = respDiag.Respuesta;

        // cargar paciente
        var respPac = await Http.Get<PacienteDTO>($"api/paciente/{Id}");
        if (!respPac.Error)
            modelo = respPac.Respuesta;
        else
            Mensaje = respPac.ObtenerError();

        cargando = false;
    }

    private async Task Grabar()
    {
        if (modelo == null) return;

        var resp = await Http.Put<PacienteDTO, RespuestaDTO>($"api/paciente/{Id}", modelo);
        Mensaje = resp.Error ? resp.ObtenerError() : resp.Respuesta?.mensaje!;

        if (!resp.Error)
        {
            await Task.Delay(500);
            Nav.NavigateTo("/pacientes", true);
        }
    }

    private void Cancelar()
    {
        Nav.NavigateTo("/pacientes");
    }
}
