@page "/pacientes"
@using CentroSenderos_2026_Shared.DTO
@inject IHttpServicio Http
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@rendermode InteractiveAuto

<h3>Listado de Pacientes</h3>

<div class="mb-3">
    <a href="/pacientes/crear" class="btn btn-primary">
        <span class="oi oi-plus"></span> Nuevo Paciente
    </a>
</div>

@if (cargando)
{
    <p>Cargando Pacientes...</p>
}
else if (listaPacientes == null || listaPacientes.Count == 0)
{
    <p>No hay pacientes registrados.</p>
}
else
{
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>DNI</th>
                        <th>Fecha Nacimiento</th>
                        <th>Nro Afiliado</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
        <tbody>
            @foreach (var paciente in listaPacientes)
            {
                <tr>
                    <td>@paciente.Id</td>
                    <td>@paciente.Nombre</td>
                    <td>@paciente.DNI</td>
                    <td>@paciente.NumeroAfiliado</td>
                    <td>@paciente.EstadoRegistro</td>
                    <td>
                        <button class="btn btn-sm btn-info" @onclick="() => MostrarDetalle(paciente.Id)">
                            <span class="oi oi-eye"></span> Detalle
                        </button>

                        <a href="/pacientes/editar/@paciente.Id" class="btn btn-sm btn-warning">
                            <span class="oi oi-pencil"></span> Editar
                        </a>
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(paciente.Id)">
                            <span class="oi oi-delete"></span> Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (mostrarModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detalle Paciente</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    @if (detallePaciente != null)
                    {
                        <p><strong>ID:</strong> @detallePaciente.Id</p>
                        <p><strong>Nombre:</strong> @detallePaciente.Nombre</p>
                        <p><strong>DNI:</strong> @detallePaciente.DNI</p>
                        @* <p><strong>Fecha Nacimiento:</strong> @detallePaciente.FechaNacimiento.ToShortDateString()</p> *@
                        <p><strong>Número Afiliado:</strong> @detallePaciente.NumeroAfiliado</p>
                        <p><strong>Teléfono:</strong> @detallePaciente.Telefono</p>
                        <p><strong>Domicilio:</strong> @detallePaciente.Domicilio</p>
                        @* <p><strong>Correo Electrónico:</strong> @detallePaciente.CorreoElectronico</p> *@
                        <p><strong>Obra Social:</strong> @detallePaciente.TipoObraSocialId</p>
                        <p><strong>Diagnóstico:</strong> @detallePaciente.TipoDiagnosticoId</p>
                        <p><strong>Estado Registro:</strong> @detallePaciente.EstadoRegistro</p>
                    }
                    else
                    {
                        <p>Cargando detalle...</p>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

<p>@Mensaje</p>
@code {
    private List<PacienteResumenDTO> listaPacientes = new();
    private bool cargando = true;
    private string Mensaje = "";
    private bool mostrarModal = false;
    private PacienteDTO? detallePaciente;

    protected override async Task OnInitializedAsync()
    {
        await CargarPacientes();
    }

    private async Task CargarPacientes()
    {
        cargando = true;
        var resp = await Http.Get<List<PacienteResumenDTO>>("api/paciente/ListaPaciente");
        if (!resp.Error)
        {
            listaPacientes = resp.Respuesta ?? new();
        }
        else
        {
            Mensaje = resp.ObtenerError();
        }
        cargando = false;
    }

    private async Task MostrarDetalle(int id)
    {
        var resp = await Http.Get<PacienteDTO>($"api/paciente/{id}");
        if (!resp.Error)
        {
            detallePaciente = resp.Respuesta;
            mostrarModal = true;
        }
        else
        {
            Mensaje = resp.ObtenerError();
        }
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        detallePaciente = null;
    }

    private async Task Eliminar(int id)
    {
        if (await Confirm("¿Está seguro que desea eliminar este paciente?"))
        {
            var resp = await Http.Delete($"api/paciente/{id}");
            if (!resp.Error)
            {
                Mensaje = "Paciente eliminado correctamente.";
                await Task.Delay(500);
                await CargarPacientes();
            }
            else
            {
                Mensaje = resp.ObtenerError();
            }
        }
    }

    private async Task<bool> Confirm(string mensaje)
    {
        return await JSRuntime.InvokeAsync<bool>("confirm", mensaje);
    }
}
