@page "/tipoturno/editar/{id:int}"
@using CentroSenderos_2026_Shared.DTO
@inject IHttpServicio Http
@inject NavigationManager Nav
@rendermode InteractiveAuto

<h3>Editar Tipo de Turno</h3>

@if (cargando)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="@modelo" OnValidSubmit="Grabar">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label>Tipo</label>
            <InputText class="form-control" @bind-Value="modelo.Tipo" />
        </div>
        <div class="form-group">
            <label>Descripción</label>
            <InputText class="form-control" @bind-Value="modelo.Descripcion" />
        </div>
        <div class="form-group">
            <label>Duración (minutos)</label>
            <InputNumber class="form-control" @bind-Value="modelo.DuracionMinutos" />
        </div>

        <button class="btn btn-primary" type="submit">Actualizar</button>
        <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
    </EditForm>
}

<p>@Mensaje</p>

@code {
    [Parameter] public int id { get; set; }
    private TipoTurnoDTO modelo = new TipoTurnoDTO
    {
        Tipo = string.Empty,
        Descripcion = string.Empty,
        DuracionMinutos = 0
    };
    private bool cargando = true;
    private string Mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.Get<TipoTurnoDTO>($"api/tipoturno/Tipo/{id}");
        modelo = resp.Error ? new TipoTurnoDTO { Tipo = string.Empty, DuracionMinutos = 0 }
                    : resp.Respuesta ?? new TipoTurnoDTO { Tipo = string.Empty, DuracionMinutos = 0 };
        Mensaje = resp.Error ? resp.ObtenerError() : "";
        cargando = false;
    }

    private async Task Grabar()
    {
        // var resp = await Http.Put($"api/tipoturno/{id}", modelo);
        var resp = await Http.Put<TipoTurnoDTO, string>($"api/tipoturno/{id}", modelo);
        Mensaje = resp.Error ? resp.ObtenerError() : "Actualizado correctamente.";
        if (!resp.Error) Nav.NavigateTo("/tipoturno", true);
    }

    private void Cancelar() => Nav.NavigateTo("/tipoturno");
}

