@page "/profesionales/editar/{id:int}"
@using CentroSenderos_2026_Shared.DTO
@inject IHttpServicio Http
@inject NavigationManager Nav
@rendermode InteractiveAuto

<h3>Editar Profesional</h3>

@if (cargando)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="@modelo" OnValidSubmit="Grabar">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <h5>Datos Personales</h5>
        <div class="form-group">
            <label>Nombre Completo</label>
            <InputText class="form-control" @bind-Value="modelo.Nombre" placeholder="Ej: Lic. Juan Carlos López" />
            <ValidationMessage For="@(() => modelo.Nombre)" />
        </div>

        <div class="form-group">
            <label>Área/Perfil</label>
            <InputText class="form-control" @bind-Value="modelo.Area" placeholder="Ej: Fisioterapeuta, Psicólogo, etc." />
            <ValidationMessage For="@(() => modelo.Area)" />
        </div>

        <h5>Datos Profesionales</h5>
        <div class="form-group">
            <label>CUIT</label>
            <InputText class="form-control" @bind-Value="modelo.Cuit" placeholder="Ej: 20-12345678-9" />
            <ValidationMessage For="@(() => modelo.Cuit)" />
@*             <InputText class="form-control" @bind-Value="modelo.Cuit" disabled /> *@

        </div>

        <div class="form-group">
            <label>MP</label>
            <InputText class="form-control" @bind-Value="modelo.MP" placeholder="Ej: MP-001" />
            <ValidationMessage For="@(() => modelo.MP)" />
        </div>

        <div class="form-group">
            <label>RNP</label>
            <InputText class="form-control" @bind-Value="modelo.RNP" placeholder="Ej: RNP-10001" />
            <ValidationMessage For="@(() => modelo.RNP)" />
        </div>

        <div class="form-group">
            <label>Teléfono de Contacto</label>
            <InputText class="form-control" @bind-Value="modelo.Telefono" placeholder="Ej: +54 11 2345-6789" />
            <ValidationMessage For="@(() => modelo.Telefono)" />
        </div>

        <br />
        <button class="btn btn-primary" type="submit">Guardar Cambios</button>
        <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
    </EditForm>
}

<p>@Mensaje</p>

@code {
    [Parameter] public int id { get; set; }
    private ProfesionalDTO modelo = new ProfesionalDTO { Nombre = string.Empty, Area = string.Empty, Cuit = string.Empty, MP = string.Empty, RNP = string.Empty, Telefono = string.Empty };
    private bool cargando = true;
    private string Mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.Get<ProfesionalDTO>($"api/profesional/{id}");
        modelo = resp.Error ? new ProfesionalDTO { Nombre = string.Empty, Area = string.Empty, Cuit = string.Empty, MP = string.Empty, RNP = string.Empty, Telefono = string.Empty }
                            : resp.Respuesta ?? new ProfesionalDTO { Nombre = string.Empty, Area = string.Empty, Cuit = string.Empty, MP = string.Empty, RNP = string.Empty, Telefono = string.Empty };
        Mensaje = resp.Error ? resp.ObtenerError() : "";

        cargando = false;

    }

    private async Task Grabar()
    {
        var resp = await Http.Put<ProfesionalDTO, RespuestaDTO>($"api/profesional/{id}", modelo);
        Mensaje = resp.Error ? resp.ObtenerError() : resp.Respuesta?.mensaje!;

        if (!resp.Error) Nav.NavigateTo("/profesionales", true);
    }

    private void Cancelar() => Nav.NavigateTo("/profesionales");

}